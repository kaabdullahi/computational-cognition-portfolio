% Matlab code for calculating and plotting the sampling distribution of 
% the distance-from-optimality in Little & Eidels scheduling data, 4/6/2020
%
% Ami Eidels, updated 22/9/2024

clear all;; close all; clc

ntrials = 200000; % number of simulated trials

% define the Optiaml Order of task-completion (1= easy, 4= hardest)
%
%optimalOrder = [1 2 3 4];
optimalOrder = [1 2 3 4 5 6 7 8];


% generate synthetic data, whereby on each 'trial' the order of four tasks
% is obtained by randoamlly permuting the optimal order. 
% Can be done faster as matrix but i preferred Loop so i can check each step
tic
for n = 1: ntrials;
    
    % ONE TRIAL, a sinlge permutation of the optimal order
    temp = randperm(length(optimalOrder)); 
    simData(n, :) = temp;
    
    % calculating the difference between EACH entry in the optimal and
    % permuted string (this gives four values which we will later sum)
    diffScore(n, :) = temp - optimalOrder;
    
end
toc
% calcualting, for each trial, the sum across four distances (consider
% ^2 instead of abs)
totalDiff = sum(abs(diffScore), 2);
%totalDiff = sqrt(sum((diffScore.^2), 2));

% Plotting the sampling distribution
figure; 
xAxis = min(totalDiff):max(totalDiff)
bar ( xAxis, hist(totalDiff, xAxis) / ntrials );
title('sampling distribution of distance-from-optimality');
xlabel('distance-from-optimality') 
ylabel('probability')


